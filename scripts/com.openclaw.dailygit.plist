<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.dailygit</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/macmini/.openclaw/workspace/scripts/daily-git-commit.sh</string>
    </array>
    
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>23</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    
    <key>WorkingDirectory</key>
    <string>/Users/macmini/.openclaw/workspace</string>
    
    <key>StandardOutPath</key>
    <string>/Users/macmini/.openclaw/workspace/scripts/launchd-git.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/macmini/.openclaw/workspace/scripts/launchd-git-error.log</string>
    
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>