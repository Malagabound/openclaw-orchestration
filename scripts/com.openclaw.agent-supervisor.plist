<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.agent-supervisor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>-m</string>
        <string>agent-dispatch.agent_supervisor</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/alanwalker/openclaw-orchestration</string>

    <key>WatchPaths</key>
    <array>
        <string>/Users/alanwalker/openclaw-orchestration/agent-dispatch/supervisor.heartbeat</string>
    </array>

    <key>ThrottleInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/alanwalker/openclaw-orchestration/agent-dispatch/logs/supervisor-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/alanwalker/openclaw-orchestration/agent-dispatch/logs/supervisor-stderr.log</string>

    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
